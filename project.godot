;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Killer Sudoku"
run/main_scene="uid://bfjc7l86edc4b"
config/auto_accept_quit=false
config/quit_on_go_back=false
config/features=PackedStringArray("4.4", "GL Compatibility")
boot_splash/show_image=false
config/icon="uid://ncbvu6e7vso2"

[autoload]

Game="*res://script/Game Logic/game_manager.gd"
TestRunner="*res://script/Test/test_runner.gd"

[display]

window/handheld/orientation=1

[file_customization]

folder_colors={
"res://Resource Base/": "red",
"res://save/": "purple",
"res://scene/": "blue",
"res://script/": "yellow",
"res://script/Test/": "gray",
"res://theme/": "green"
}

[global_group]

has_config=""

